# ── Backend ──────────────────────────────────────────────────────────────────

# Port the Go server listens on (Cloud Run sets this automatically)
PORT=8080

# Path to the inspection module JSON files
ARGUS_MODULES_DIR=./modules

# ── Gemini / Vertex AI ───────────────────────────────────────────────────────

# Backend: "vertex_ai" (default) or "gemini_api"
# Vertex AI uses the stable native audio model with robust function calling.
# GEMINI_BACKEND=vertex_ai

# Vertex AI (default) — uses Application Default Credentials (ADC)
# Run: gcloud auth application-default login
GCP_PROJECT_ID=your_gcp_project_id
GCP_LOCATION=us-central1

# Gemini API (AI Studio) fallback — only if GEMINI_BACKEND=gemini_api
# GEMINI_API_KEY=your_gemini_api_key_here

# Demo access codes — comma-separated, users enter one of these to access /session
# Leave empty to disable the gate (open access)
DEMO_TOKENS=

# ── Frontend (Next.js) ────────────────────────────────────────────────────────

# WebSocket backend URL — must start with ws:// or wss://
# Local dev:  ws://localhost:8080/ws
# Production: wss://your-cloud-run-url/ws
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
