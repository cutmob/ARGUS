# ARGUS Configuration
PORT=8080
ARGUS_MODULES_DIR=./modules
ARGUS_REPORTS_DIR=./reports

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Webhook Integration
ARGUS_WEBHOOK_URL=https://your-webhook-endpoint.com/argus

# Slack Integration (optional)
ARGUS_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
ARGUS_SLACK_CHANNEL=#safety-alerts

# Email Integration (optional)
ARGUS_SMTP_HOST=smtp.gmail.com
ARGUS_SMTP_PORT=587
ARGUS_EMAIL_FROM=argus@yourcompany.com
ARGUS_EMAIL_PASSWORD=your_app_password

# Frontend
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
